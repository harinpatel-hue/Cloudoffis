{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@utils/*": ["./utils/*"],
      "@types/*": ["./types/*"],
      "@constants/*": ["./constants/*"],
      "@test-data/*": ["./test-data/*"],
      "@ai/*": ["./ai/*"]
    }
  },
  "include": ["pages/**/*", "fixtures/**/*", "utils/**/*", "constants/**/*", "tests/**/*", "ai/**/*"]
}
