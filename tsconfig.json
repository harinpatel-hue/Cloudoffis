{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@utils/*": ["./utils/*"],
      "@types/*": ["./types/*"],
      "@constants/*": ["./constants/*"],
      "@test-data/*": ["./test-data/*"]
    }
  },
  "include": ["pages/**/*", "fixtures/**/*", "utils/**/*", "constants/**/*", "tests/**/*"]
}
